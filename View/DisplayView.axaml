<UserControl xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QManager.ViewModels"
        xmlns:svc="using:QManager.Service"
        x:Class="QManager.View.DisplayView"
        Background="Transparent">
    
    <Design.DataContext>
        <vm:DisplayViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="22" VerticalAlignment="Center" HorizontalAlignment="Center" Width="480">
        <TextBlock Text="{Binding [DisplaySettings], Source={x:Static svc:LocalizationService.Instance}}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>
        
        <StackPanel Spacing="5">
            <TextBlock Text="{Binding [Resolution], Source={x:Static svc:LocalizationService.Instance}}" FontSize="16" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Resolutions}"
                      SelectedItem="{Binding SelectedResolution}" 
                      HorizontalAlignment="Stretch"
                      Height="45"/>
        </StackPanel>

        <ToggleSwitch Content="{Binding [FullscreenMode], Source={x:Static svc:LocalizationService.Instance}}" 
                      IsChecked="{Binding IsFullscreen}" 
                      OnContent="On" OffContent="Off"/>

        <Button Content="{Binding [Apply], Source={x:Static svc:LocalizationService.Instance}}" 
                Command="{Binding ApplySettingsCommand}" 
                Classes="nav"
                Width="200"
                Height="48"
                HorizontalAlignment="Center" 
                Margin="0,20,0,0"/>

        <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}" 
                Click="Back_Click" 
                Classes="nav"
                Width="200"
                Height="48"
                HorizontalAlignment="Center" 
                Margin="0,10,0,0"/>
    </StackPanel>
</UserControl>