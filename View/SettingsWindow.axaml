<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:QManager.Service"
             x:Class="QManager.View.SettingsView"
             Background="Transparent">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
        </Style>

        <Style Selector="Button.nav:focus">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Grid Margin="26,18,26,18" RowDefinitions="Auto,*,Auto,Auto">
            <!-- Header -->
            <Grid Grid.Row="0" ColumnDefinitions="Auto,*,Auto" VerticalAlignment="Center">

                <Button Grid.Column="0"
                        Classes="nav"
                        Content="{Binding [ChangeAdminName], Source={x:Static svc:LocalizationService.Instance}}"
                        HorizontalAlignment="Left"
                        CornerRadius="12"
                        Click="ChangeAdminName_Click" />

                <!-- Admin Name + Avatar Oval (Right) -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">
                    <Border Height="42"
                            Padding="16,0"
                            CornerRadius="12"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1.5"
                            Background="{DynamicResource PanelBgBrush}">
                        <TextBlock x:Name="CurrentAdminNameText"
                                   VerticalAlignment="Center"
                                   FontWeight="SemiBold"
                                   Text="---" />
                    </Border>
                    <Button Classes="nav"
                            Width="48"
                            Height="48"
                            CornerRadius="24"
                            Padding="0"
                            Click="ChangePhoto_Click">
                        <Border Width="48"
                                Height="48"
                                CornerRadius="24"
                                ClipToBounds="True"
                                BorderBrush="{DynamicResource BorderBrush}"
                                BorderThickness="1.5"
                                Background="{DynamicResource PanelBgBrush}">
                            <Panel>
                                <TextBlock HorizontalAlignment="Center"
                                           VerticalAlignment="Center"
                                           FontSize="20"
                                           Text="{Binding [AdminInitial], Source={x:Static svc:LocalizationService.Instance}}"
                                           IsVisible="{Binding ProfileImage, Converter={x:Static ObjectConverters.IsNull}}" />
                                <Image Source="{Binding ProfileImage}"
                                       Stretch="UniformToFill" />
                            </Panel>
                        </Border>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Central Area -->
            <StackPanel Grid.Row="1"
                        VerticalAlignment="Center"
                        HorizontalAlignment="Center"
                        Spacing="22">
                <Button Classes="nav" Width="480" Height="54" CornerRadius="12" FontSize="18" Content="{Binding [ChangePassword], Source={x:Static svc:LocalizationService.Instance}}" Click="ChangePassword_Click" />
                <Button Classes="nav" Width="480" Height="54" CornerRadius="12" FontSize="18" Content="{Binding [ChangeLanguage], Source={x:Static svc:LocalizationService.Instance}}" Click="ChangeLanguage_Click" />
                <Button Classes="nav" Width="480" Height="54" CornerRadius="12" FontSize="18" Content="{Binding [AboutUs], Source={x:Static svc:LocalizationService.Instance}}" Click="AboutUs_Click" />

                <TextBlock x:Name="SettingsStatusText"
                           Margin="0,10,0,0"
                           HorizontalAlignment="Center"
                           Foreground="{DynamicResource SubTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>

            <!-- Separator Line (Dotted) -->
            <Rectangle Grid.Row="2" 
                       Height="1.5" 
                       Margin="0,20"
                       Fill="Transparent" 
                       Stroke="{DynamicResource BorderBrush}" 
                       StrokeDashArray="4,4" 
                       StrokeThickness="1.5" />

            <!-- Footer -->
            <Grid Grid.Row="3" ColumnDefinitions="*,Auto,*">
                <Button Grid.Column="1"
                        Classes="nav"
                        Width="200"
                        Height="48"
                        CornerRadius="24"
                        Content="{Binding [SignOut], Source={x:Static svc:LocalizationService.Instance}}"
                        Click="SignOut_Click" />

                <ToggleSwitch Grid.Column="2"
                              HorizontalAlignment="Right"
                              IsChecked="{Binding IsDarkMode}"
                              Content="{Binding [DarkLightMode], Source={x:Static svc:LocalizationService.Instance}}" />
            </Grid>
        </Grid>
    </Grid>
</UserControl>
