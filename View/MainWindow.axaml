<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:anim="clr-namespace:Avalonia.Animation;assembly=Avalonia.Base"
    xmlns:svc="using:QManager.Service"
        x:Class="QManager.View.MainWindow"
        Title="Bank"
        Width="1080"
        Height="720"
        MinWidth="980"
        MinHeight="660"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="{DynamicResource WindowBgBrush}">
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.menu">
            <Setter Property="Width" Value="190" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.menu:disabled">
            <Setter Property="Background" Value="{DynamicResource NavBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.action">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="TextBox.form">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="CaretBrush" Value="{DynamicResource MainTextBrush}" />
        </Style>

        <Style Selector="TextBox.form:focus">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="CaretBrush" Value="{DynamicResource MainTextBrush}" />
        </Style>
    </Window.Styles>

    <Border Margin="10"
            Background="{DynamicResource MainBorderBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            CornerRadius="16">
        <Grid RowDefinitions="42,*">
            <Border Grid.Row="0"
                    Background="{DynamicResource HeaderBgBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,2"
                    CornerRadius="16,16,0,0">
                <Grid ColumnDefinitions="90,*,90">
                    <StackPanel Grid.Column="0"
                                Margin="18,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="10">
                        <Ellipse Width="10" Height="10" Stroke="{DynamicResource BorderBrush}" StrokeThickness="2" />
                        <Ellipse Width="10" Height="10" Stroke="{DynamicResource BorderBrush}" StrokeThickness="2" />
                        <Ellipse Width="10" Height="10" Stroke="{DynamicResource BorderBrush}" StrokeThickness="2" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="QManager" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="96,*">
                <Border Grid.Column="0"
                        Background="{DynamicResource NavBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="0,0,2,0" />

                <Grid Grid.Column="0">
                    <Button x:Name="MenuButton"
                            Width="58"
                            Height="58"
                            Margin="0,26,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="{DynamicResource PanelBgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="1.5"
                            CornerRadius="18"
                            Padding="0"
                            ZIndex="40"
                            Click="ToggleMenu_Click">
                        <StackPanel
                              VerticalAlignment="Center"
                              HorizontalAlignment="Center"
                              Spacing="5"
                              Width="34"
                              Height="34">
                            <Border
                                    Height="4"
                                    CornerRadius="2"
                                    Background="{DynamicResource BorderBrush}" />
                            <Border
                                    Height="4"
                                    CornerRadius="2"
                                    Background="{DynamicResource BorderBrush}" />
                            <Border
                                    Height="4"
                                    CornerRadius="2"
                                    Background="{DynamicResource BorderBrush}"
                                    />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Column="1"
                        Margin="26"
                        Background="{DynamicResource PanelBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="10">
                    <TransitioningContentControl x:Name="MainContentPresenter"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch">
                        <TransitioningContentControl.PageTransition>
                            <anim:CrossFade Duration="0:0:0.22" />
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>
                </Border>

                <Button x:Name="MenuBackdrop"
                        Grid.ColumnSpan="2"
                        Background="#22000000"
                        BorderThickness="0"
                        IsVisible="False"
                        ZIndex="20"
                        Padding="0"
                        Click="HideMenu_Click" />

                <Border x:Name="MenuPanel"
                        Grid.ColumnSpan="2"
                        Width="246"
                        Margin="20,20,0,20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="{DynamicResource MainBorderBgBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"
                        BorderThickness="2"
                        CornerRadius="14"
                        IsVisible="False"
                        PointerPressed="MenuPanel_PointerPressed"
                        ZIndex="30">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="18">
                        <StackPanel Orientation="Horizontal" Spacing="12">
                            <Border Width="44" Height="44" CornerRadius="22" ClipToBounds="True" 
                                    Background="{DynamicResource PanelBgBrush}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1.5">
                                <Panel>
                                    <TextBlock Text="{Binding [AdminInitial], Source={x:Static svc:LocalizationService.Instance}}"
                                               HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="18"
                                               IsVisible="{Binding #MenuAvatarImage.Source, Converter={x:Static ObjectConverters.IsNull}}" />
                                    <Image x:Name="MenuAvatarImage" Stretch="UniformToFill" />
                                </Panel>
                            </Border>
                            <StackPanel Spacing="2" VerticalAlignment="Center">
                                <TextBlock x:Name="MenuUserText"
                                           FontSize="18"
                                           FontWeight="SemiBold"
                                           Text="Admin Name" />
                                <TextBlock Foreground="{DynamicResource SubTextBrush}"
                                           Text="Navigation" />
                            </StackPanel>
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,24,0,0"
                                    Spacing="12">
                            <Button Classes="menu"
                                    Content="{Binding [Bank], Source={x:Static svc:LocalizationService.Instance}}"
                                    Click="OpenBank_Click" />
                            <Button Classes="menu"
                                    Content="{Binding [Talon], Source={x:Static svc:LocalizationService.Instance}}"
                                    Click="OpenTalon_Click" />
                            <Button Classes="menu"
                                    Content="{Binding [Dashboard], Source={x:Static svc:LocalizationService.Instance}}"
                                    Click="OpenDashboard_Click" />
                            <Button Classes="menu"
                                    Content="{Binding [SystemSettings], Source={x:Static svc:LocalizationService.Instance}}"
                                    Click="OpenSettings_Click" />
                        </StackPanel>

                    <Button Grid.Row="2"
                            Classes="menu"
                            Content="{Binding [ExitApp], Source={x:Static svc:LocalizationService.Instance}}"
                            Click="ExitApp_Click" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
