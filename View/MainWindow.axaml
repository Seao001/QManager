<Window xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:anim="clr-namespace:Avalonia.Animation;assembly=Avalonia.Base"
        x:Class="QManager.View.MainWindow"
        Title="Bank"
        Width="1080"
        Height="720"
        MinWidth="980"
        MinHeight="660"
        WindowState="Maximized"
        WindowStartupLocation="CenterScreen"
        Background="#EDEAE3">
    <Window.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#1F252B" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.menu">
            <Setter Property="Width" Value="190" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
            <Setter Property="Background" Value="#FBFAF6" />
            <Setter Property="BorderBrush" Value="#2A3138" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#1F252B" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.menu:disabled">
            <Setter Property="Background" Value="#D9E2EC" />
            <Setter Property="Foreground" Value="#1F252B" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.action">
            <Setter Property="Background" Value="#FBFAF6" />
            <Setter Property="BorderBrush" Value="#2A3138" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#1F252B" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="16,10" />
            <Setter Property="FontSize" Value="15" />
        </Style>

        <Style Selector="TextBox.form">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#2A3138" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="#1F252B" />
            <Setter Property="Padding" Value="10,8" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="CaretBrush" Value="#1F252B" />
        </Style>

        <Style Selector="TextBox.form:focus">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="Foreground" Value="#1F252B" />
            <Setter Property="CaretBrush" Value="#1F252B" />
        </Style>
    </Window.Styles>

    <Border Margin="10"
            Background="#F7F5EF"
            BorderBrush="#2A3138"
            BorderThickness="2"
            CornerRadius="16">
        <Grid RowDefinitions="42,*">
            <Border Grid.Row="0"
                    Background="#E4E0D7"
                    BorderBrush="#2A3138"
                    BorderThickness="0,0,0,2"
                    CornerRadius="16,16,0,0">
                <Grid ColumnDefinitions="90,*,90">
                    <StackPanel Grid.Column="0"
                                Margin="18,0,0,0"
                                Orientation="Horizontal"
                                VerticalAlignment="Center"
                                Spacing="10">
                        <Ellipse Width="10" Height="10" Stroke="#2A3138" StrokeThickness="2" />
                        <Ellipse Width="10" Height="10" Stroke="#2A3138" StrokeThickness="2" />
                        <Ellipse Width="10" Height="10" Stroke="#2A3138" StrokeThickness="2" />
                    </StackPanel>

                    <TextBlock Grid.Column="1"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"
                               FontSize="18"
                               FontWeight="SemiBold"
                               Text="Bank" />
                </Grid>
            </Border>

            <Grid Grid.Row="1" ColumnDefinitions="96,*">
                <Border Grid.Column="0"
                        Background="#F0ECE3"
                        BorderBrush="#2A3138"
                        BorderThickness="0,0,2,0" />

                <Grid Grid.Column="0">
                    <Button x:Name="MenuButton"
                            Width="58"
                            Height="58"
                            Margin="0,26,0,0"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Top"
                            Background="#FBFAF6"
                            BorderBrush="#2A3138"
                            BorderThickness="1.5"
                            CornerRadius="18"
                            Padding="0"
                            ZIndex="40"
                            Click="ToggleMenu_Click">
                        <StackPanel
                              VerticalAlignment="Center"
                              Spacing="5"
                              Width="34"
                              Height="34">
                            <Border
                                    Height="4"
                                    CornerRadius="2"
                                    Background="#2A3138" />
                            <Border
                                    Height="4"
                                    CornerRadius="2"
                                    Background="#2A3138" />
                            <Border
                                    Height="4"
                                    CornerRadius="2"
                                    Background="#2A3138"
                                    />
                        </StackPanel>
                    </Button>
                </Grid>

                <Border Grid.Column="1"
                        Margin="26"
                        Background="#FBFAF6"
                        BorderBrush="#2A3138"
                        BorderThickness="2"
                        CornerRadius="10">
                    <TransitioningContentControl x:Name="MainContentPresenter"
                                                  HorizontalAlignment="Stretch"
                                                  VerticalAlignment="Stretch">
                        <TransitioningContentControl.PageTransition>
                            <anim:CrossFade Duration="0:0:0.22" />
                        </TransitioningContentControl.PageTransition>
                    </TransitioningContentControl>
                </Border>

                <Button x:Name="MenuBackdrop"
                        Grid.ColumnSpan="2"
                        Background="#22000000"
                        BorderThickness="0"
                        IsVisible="False"
                        ZIndex="20"
                        Padding="0"
                        Click="HideMenu_Click" />

                <Border x:Name="MenuPanel"
                        Grid.ColumnSpan="2"
                        Width="246"
                        Margin="20,20,0,20"
                        HorizontalAlignment="Left"
                        VerticalAlignment="Stretch"
                        Background="#F7F5EF"
                        BorderBrush="#2A3138"
                        BorderThickness="2"
                        CornerRadius="14"
                        IsVisible="False"
                        ZIndex="30">
                    <Grid RowDefinitions="Auto,*,Auto" Margin="18">
                        <StackPanel Spacing="8">
                            <TextBlock x:Name="MenuUserText"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       Text="Admin Name" />
                            <TextBlock Foreground="#5E6872"
                                       Text="Navigation" />
                        </StackPanel>

                        <StackPanel Grid.Row="1"
                                    Margin="0,24,0,0"
                                    Spacing="12">
                            <Button Classes="menu"
                                    Content="Bank"
                                    Click="OpenBank_Click" />
                            <Button Classes="menu"
                                    Content="Casier"
                                    Click="OpenTalon_Click" />
                            <Button Classes="menu"
                                    Content="Dashboard"
                                    Click="OpenDashboard_Click" />
                            <Button Classes="menu"
                                    Content="Settings"
                                    Click="OpenSettings_Click" />
                        </StackPanel>

                        <TextBlock Grid.Row="2"
                                   Foreground="#5E6872"
                                   Text="Select a page to navigate." />
                    </Grid>
                </Border>
            </Grid>
        </Grid>
    </Border>
</Window>
