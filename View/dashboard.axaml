<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:QManager.Service"
             x:Class="QManager.View.DashboardView"
             Background="{DynamicResource WindowBgBrush}">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.menu">
            <Setter Property="Width" Value="220" />
            <Setter Property="HorizontalAlignment" Value="Center" />
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,10" />
            <Setter Property="FontSize" Value="16" />
            <Setter Property="HorizontalContentAlignment" Value="Left" />
        </Style>

        <Style Selector="Button.menu:disabled">
            <Setter Property="Background" Value="{DynamicResource NavBgBrush}" />
            <Setter Property="Opacity" Value="1" />
        </Style>

        <Style Selector="Button.action">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="CornerRadius" Value="10" />
            <Setter Property="Padding" Value="14,8" />
        </Style>

        <Style Selector="Button.ticket">
            <Setter Property="Width" Value="118" />
            <Setter Property="Height" Value="112" />
            <Setter Property="Margin" Value="0,0,14,16" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalContentAlignment" Value="Stretch" />
            <Setter Property="VerticalContentAlignment" Value="Stretch" />
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.8" />
            <Setter Property="CornerRadius" Value="0" />
        </Style>

        <Style Selector="Border.ticket">
            <Setter Property="Width" Value="136" />
            <Setter Property="Height" Value="122" />
            <Setter Property="Margin" Value="0,0,14,16" />
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.8" />
        </Style>
    </UserControl.Styles>

    <Grid Margin="24" RowDefinitions="Auto,*">
                        <Grid ColumnDefinitions="*,Auto,Auto,Auto">
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <TextBlock FontSize="24"
                                           FontWeight="SemiBold"
                                           Text="{Binding WaitingNowText}" 
                                           VerticalAlignment="Center"/>
                                
                                <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                                    <TextBlock Text="{Binding [BankFilterLabel], Source={x:Static svc:LocalizationService.Instance}}" VerticalAlignment="Center" FontWeight="SemiBold"/>
                                    <ComboBox ItemsSource="{Binding Banks}"
                                              SelectedItem="{Binding SelectedBank}"
                                              Width="180"
                                              Height="38"
                                              VerticalAlignment="Center">
                                        <ComboBox.ItemTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding}" VerticalAlignment="Center"/>
                                            </DataTemplate>
                                        </ComboBox.ItemTemplate>
                                    </ComboBox>
                                </StackPanel>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Classes="action"
                                    Margin="0,0,12,0"
                                    Content="{Binding [ResetQueue], Source={x:Static svc:LocalizationService.Instance}}"
                                    Click="ResetQueue_Click" />
                            <Button Grid.Column="3"
                                    Classes="action"
                                    Content="{Binding [ExportData], Source={x:Static svc:LocalizationService.Instance}}"
                                    Click="ExportData_Click" />
                        </Grid>

                        <Grid Grid.Row="1"
                              Margin="0,24,0,0"
                              ColumnDefinitions="*,2,*">
                            <StackPanel Grid.Column="0" Spacing="18">
                                <TextBlock FontSize="36"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Text="{Binding [InWaitingHeader], Source={x:Static svc:LocalizationService.Instance}}" />

                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding OnHoldTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="ticket"
                                                        Tag="{Binding}"
                                                        Click="MoveToReady_Click"
                                                        Padding="8">
                                                    <Grid RowDefinitions="Auto,1,*,Auto">
                                                        <TextBlock HorizontalAlignment="Left" FontSize="10" Text="Talon" Opacity="0.6" />
                                                        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                                                        <TextBlock Grid.Row="2" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   FontSize="28" 
                                                                   FontWeight="Bold" 
                                                                   Text="{Binding Talon}" />
                                                        <TextBlock Grid.Row="3" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="14" 
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>

                            <Border Grid.Column="1"
                                    Background="{DynamicResource BorderBrush}"
                                    Margin="0,12" />

                            <StackPanel Grid.Column="2"
                                        Margin="24,0,0,0"
                                        Spacing="18">
                                <TextBlock FontSize="36"
                                           FontWeight="SemiBold"
                                           HorizontalAlignment="Center"
                                           Text="{Binding [ReadyHeader], Source={x:Static svc:LocalizationService.Instance}}" />

                                <ScrollViewer>
                                    <ItemsControl ItemsSource="{Binding ReadyTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Button Classes="ticket"
                                                        Tag="{Binding}"
                                                        Click="MoveToOnHold_Click"
                                                        Padding="8">
                                                    <Grid RowDefinitions="Auto,1,*,Auto">
                                                        <TextBlock HorizontalAlignment="Left" FontSize="10" Text="Talon" Opacity="0.6" />
                                                        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                                                        <TextBlock Grid.Row="2" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   FontSize="28" 
                                                                   FontWeight="Bold" 
                                                                   Text="{Binding Talon}" />
                                                        <TextBlock Grid.Row="3" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="14" 
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Button>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </StackPanel>
                        </Grid>
    </Grid>
</UserControl>
