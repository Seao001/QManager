<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QManager.View.TalonView"
             Background="Transparent">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="#22262B" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#22262B" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Foreground" Value="#22262B" />
        </Style>

        <Style Selector="Border.ticket">
            <Setter Property="Background" Value="#FFFFFF" />
            <Setter Property="BorderBrush" Value="#22262B" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border Margin="24,16,24,16"
                            Background="#FBFBF8"
                            BorderBrush="#22262B"
                            BorderThickness="2">
            <Grid Margin="18,14,18,18" RowDefinitions="Auto,*">
                            <Grid ColumnDefinitions="*,1,*" Margin="12,0,12,8">
                                <TextBlock FontSize="30"
                                           HorizontalAlignment="Center"
                                           Text="On hold" />
                                <Border Grid.Column="1"
                                        Width="1"
                                        Background="#22262B"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch" />
                                <TextBlock Grid.Column="2"
                                           FontSize="30"
                                           HorizontalAlignment="Center"
                                           Text="Ready for service" />
                            </Grid>

                            <Grid Grid.Row="1" ColumnDefinitions="*,1,*">
                                <Border Grid.Column="1"
                                        Background="#22262B"
                                        Width="1"
                                        Margin="0,0,0,0"
                                        BorderBrush="#22262B"
                                        BorderThickness="0" />

                                <ScrollViewer Grid.Column="0" Margin="0,0,12,0">
                                    <ItemsControl ItemsSource="{Binding OnHoldTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="ticket" Width="118" Height="112" Margin="0,0,14,16">
                                                    <Grid RowDefinitions="26,34,1,*">
                                                        <TextBlock Margin="4,0"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Text="Talon" />
                                                        <Border Grid.Row="1"
                                                                BorderBrush="#22262B"
                                                                BorderThickness="0,1.5,0,1.5">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"
                                                                       Text="{Binding Talon}" />
                                                        </Border>
                                                        <TextBlock Grid.Row="3"
                                                                   Margin="6,8,6,0"
                                                                   FontSize="13"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <ScrollViewer Grid.Column="2" Margin="12,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReadyTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="ticket" Width="118" Height="112" Margin="0,0,14,16">
                                                    <Grid RowDefinitions="26,34,1,*">
                                                        <TextBlock Margin="4,0"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Text="Talon" />
                                                        <Border Grid.Row="1"
                                                                BorderBrush="#22262B"
                                                                BorderThickness="0,1.5,0,1.5">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"
                                                                       Text="{Binding Talon}" />
                                                        </Border>
                                                        <TextBlock Grid.Row="3"
                                                                   Margin="6,8,6,0"
                                                                   FontSize="13"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
