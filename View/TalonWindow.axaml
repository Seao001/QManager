<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:svc="using:QManager.Service"
             x:Class="QManager.View.TalonView"
             Background="{DynamicResource WindowBgBrush}">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
        </Style>

        <Style Selector="Border.ticket">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border Margin="24,16,24,16"
                            Background="{DynamicResource MainBorderBgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2">
            <Grid Margin="18,14,18,18" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,*,*">
                    <TextBlock Text="{Binding DisplayBankName}"
                               Grid.Row="0"
                               Grid.Column="0"
                               Grid.ColumnSpan="2"
                               FontSize="38"
                               FontWeight="Bold"
                               VerticalAlignment="Center"
                               Margin="10,0,0,0" />

                    <TextBlock x:Name="RealTimeClock"
                               Grid.Row="0"
                               Grid.Column="2"
                               FontSize="46"
                               FontWeight="Medium"
                               Foreground="{DynamicResource MainTextBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"
                               HorizontalAlignment="Right"/>

                            <Grid Grid.Row="1" Grid.ColumnSpan="3" ColumnDefinitions="*,1,*" Margin="12,0,12,8">
                                <TextBlock FontSize="30"
                                           HorizontalAlignment="Center"
                                           Text="{Binding [InWaitingHeader], Source={x:Static svc:LocalizationService.Instance}}" />
                                <Border Grid.Column="1"
                                        Width="1"
                                        Background="{DynamicResource BorderBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch" />
                                <TextBlock Grid.Column="2"
                                           FontSize="30"
                                           HorizontalAlignment="Center"
                                           Text="{Binding [ReadyHeader], Source={x:Static svc:LocalizationService.Instance}}" />
                            </Grid>

                            <Grid Grid.Row="2" Grid.ColumnSpan="3" ColumnDefinitions="*,1,*">
                                <Border Grid.Column="1"
                                        Background="{DynamicResource BorderBrush}"
                                        Width="1"
                                        Margin="0,0,0,0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0" />

                                <ScrollViewer Grid.Column="0" Margin="0,0,12,0">
                                    <ItemsControl ItemsSource="{Binding OnHoldTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="ticket" Width="118" Height="112" Margin="0,0,14,16" Padding="8">
                                                    <Grid RowDefinitions="Auto,1,*,Auto">
                                                        <TextBlock HorizontalAlignment="Left" FontSize="10" Text="Talon" Opacity="0.6" />
                                                        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                                                        <TextBlock Grid.Row="2" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   FontSize="28" 
                                                                   FontWeight="Bold" 
                                                                   Text="{Binding Talon}" />
                                                        <TextBlock Grid.Row="3" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="14" 
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <ScrollViewer Grid.Column="2" Margin="12,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReadyTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="ticket" Width="118" Height="112" Margin="0,0,14,16" Padding="8">
                                                    <Grid RowDefinitions="Auto,1,*,Auto">
                                                        <TextBlock HorizontalAlignment="Left" FontSize="10" Text="Talon" Opacity="0.6" />
                                                        <Border Grid.Row="1" Background="{DynamicResource BorderBrush}" Height="1" Margin="0,4"/>
                                                        <TextBlock Grid.Row="2" 
                                                                   HorizontalAlignment="Center" 
                                                                   VerticalAlignment="Center" 
                                                                   FontSize="28" 
                                                                   FontWeight="Bold" 
                                                                   Text="{Binding Talon}" />
                                                        <TextBlock Grid.Row="3" 
                                                                   HorizontalAlignment="Center" 
                                                                   FontSize="14" 
                                                                   FontWeight="SemiBold"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
