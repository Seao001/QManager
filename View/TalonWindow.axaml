<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QManager.View.TalonView"
             Background="{DynamicResource WindowBgBrush}">
    <UserControl.Styles>
        <Style Selector="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
        </Style>

        <Style Selector="Button.nav">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="CornerRadius" Value="12" />
            <Setter Property="Padding" Value="14,7" />
            <Setter Property="Foreground" Value="{DynamicResource MainTextBrush}" />
        </Style>

        <Style Selector="Border.ticket">
            <Setter Property="Background" Value="{DynamicResource PanelBgBrush}" />
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}" />
            <Setter Property="BorderThickness" Value="1.5" />
            <Setter Property="Padding" Value="0" />
        </Style>
    </UserControl.Styles>

    <Grid>
        <Border Margin="24,16,24,16"
                            Background="{DynamicResource MainBorderBgBrush}"
                            BorderBrush="{DynamicResource BorderBrush}"
                            BorderThickness="2">
            <Grid Margin="18,14,18,18" RowDefinitions="Auto,Auto,*" ColumnDefinitions="*,*,*">
                    <TextBlock x:Name="RealTimeClock"
                               Grid.Row="0"
                               Grid.Column="2"
                               FontSize="46"
                               FontWeight="Medium"
                               Foreground="#1F252B"
                               VerticalAlignment="Center"
                               Margin="0,0,20,0"
                               HorizontalAlignment="Right"/>

                            <Grid Grid.Row="1" Grid.ColumnSpan="3" ColumnDefinitions="*,1,*" Margin="12,0,12,8">
                                <TextBlock FontSize="30"
                                           HorizontalAlignment="Center"
                                           Text="On hold" />
                                <Border Grid.Column="1"
                                        Width="1"
                                        Background="{DynamicResource BorderBrush}"
                                        HorizontalAlignment="Center"
                                        VerticalAlignment="Stretch" />
                                <TextBlock Grid.Column="2"
                                           FontSize="30"
                                           HorizontalAlignment="Center"
                                           Text="Ready for service" />
                            </Grid>

                            <Grid Grid.Row="2" Grid.ColumnSpan="3" ColumnDefinitions="*,1,*">
                                <Border Grid.Column="1"
                                        Background="{DynamicResource BorderBrush}"
                                        Width="1"
                                        Margin="0,0,0,0"
                                        BorderBrush="{DynamicResource BorderBrush}"
                                        BorderThickness="0" />

                                <ScrollViewer Grid.Column="0" Margin="0,0,12,0">
                                    <ItemsControl ItemsSource="{Binding OnHoldTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="ticket" Width="118" Height="112" Margin="0,0,14,16">
                                                    <Grid RowDefinitions="26,34,1,*">
                                                        <TextBlock Margin="4,0"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Text="Talon" />
                                                        <Border Grid.Row="1"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,1.5,0,1.5">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"
                                                                       Text="{Binding Talon}" />
                                                        </Border>
                                                        <TextBlock Grid.Row="3"
                                                                   Margin="6,8,6,0"
                                                                   FontSize="13"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <ScrollViewer Grid.Column="2" Margin="12,0,0,0">
                                    <ItemsControl ItemsSource="{Binding ReadyTickets}">
                                        <ItemsControl.ItemsPanel>
                                            <ItemsPanelTemplate>
                                                <WrapPanel />
                                            </ItemsPanelTemplate>
                                        </ItemsControl.ItemsPanel>
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Classes="ticket" Width="118" Height="112" Margin="0,0,14,16">
                                                    <Grid RowDefinitions="26,34,1,*">
                                                        <TextBlock Margin="4,0"
                                                                   VerticalAlignment="Center"
                                                                   FontSize="13"
                                                                   Text="Talon" />
                                                        <Border Grid.Row="1"
                                                                BorderBrush="{DynamicResource BorderBrush}"
                                                                BorderThickness="0,1.5,0,1.5">
                                                            <TextBlock HorizontalAlignment="Center"
                                                                       VerticalAlignment="Center"
                                                                       FontSize="14"
                                                                       Text="{Binding Talon}" />
                                                        </Border>
                                                        <TextBlock Grid.Row="3"
                                                                   Margin="6,8,6,0"
                                                                   FontSize="13"
                                                                   Text="{Binding RoomLabel}" />
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </Grid>
            </Grid>
        </Border>
    </Grid>
</UserControl>
