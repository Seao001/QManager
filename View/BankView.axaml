<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             x:Class="QManager.View.BankView"
             Background="{DynamicResource WindowBgBrush}"
             Focusable="True"
             PointerPressed="OnPointerPressed">
    <Border Background="{DynamicResource MainBorderBgBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="2"
            CornerRadius="10"
            Margin="0">
        <Grid Margin="34" RowDefinitions="Auto,Auto,Auto,*">

            <Grid Grid.Row="2"
                  Margin="0,40,0,0"
                  ColumnDefinitions="*,36,*">
                <StackPanel Grid.Column="0" Spacing="10">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Talon" />
                    <TextBox x:Name="TalonTextBox"
                             Classes="form"
                             Height="42"
                             Watermark="Ex: A11" />
                    <Button Classes="action"
                            Width="220"
                            Content="Generate Talon"
                            Click="GenerateTalon_Click" />
                </StackPanel>

                <Border Grid.Column="1"
                        Width="2"
                        Margin="17,8"
                        Background="{DynamicResource SubTextBrush}"
                        HorizontalAlignment="Center" />

                <StackPanel Grid.Column="2" Spacing="10">
                    <TextBlock FontSize="18" FontWeight="SemiBold" Text="Room" />
                    <TextBox x:Name="RoomTextBox"
                             Classes="form"
                             Height="42"
                             Watermark="Ex: 03" />
                </StackPanel>
            </Grid>

            <StackPanel Grid.Row="3"
                        VerticalAlignment="Bottom"
                        Spacing="14">
                <Button Classes="action"
                        Width="180"
                        HorizontalAlignment="Center"
                        Content="Add Ticket"
                        Click="AddTicket_Click" />
                <TextBlock x:Name="StatusTextBlock"
                           HorizontalAlignment="Center"
                           TextAlignment="Center"
                           Foreground="{DynamicResource MainTextBrush}"
                           TextWrapping="Wrap" />
            </StackPanel>
        </Grid>
    </Border>
</UserControl>
