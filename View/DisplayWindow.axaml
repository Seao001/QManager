<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:QManager.ViewModels"
        x:Class="QManager.View.DisplayWindow"
        Title="Display Settings" 
        Width="350" Height="250"
        WindowStartupLocation="CenterScreen"
        CanResize="False">
    
    <Design.DataContext>
        <vm:DisplayViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="15" VerticalAlignment="Center">
        <StackPanel Spacing="5">
            <TextBlock Text="Resolution" FontSize="14" FontWeight="SemiBold"/>
            <ComboBox ItemsSource="{Binding Resolutions}" 
                      SelectedItem="{Binding SelectedResolution}" 
                      HorizontalAlignment="Stretch"/>
        </StackPanel>

        <ToggleSwitch Content="Fullscreen Mode" 
                      IsChecked="{Binding IsFullscreen}" 
                      OnContent="On" OffContent="Off"/>

        <Button Content="Apply" 
                Command="{Binding ApplySettingsCommand}" 
                HorizontalAlignment="Center" 
                Padding="20,5" Margin="0,10,0,0"/>
    </StackPanel>
</Window>