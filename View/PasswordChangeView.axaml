<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:QManager.ViewModels"
             xmlns:svc="using:QManager.Service"
             x:Class="QManager.View.PasswordChangeView"
             Background="Transparent">

    <Design.DataContext>
        <vm:PasswordChangeViewModel/>
    </Design.DataContext>

    <StackPanel Margin="20" Spacing="22" VerticalAlignment="Center" HorizontalAlignment="Center" Width="480">
        <TextBlock Text="{Binding [ChangePassword], Source={x:Static svc:LocalizationService.Instance}}" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Spacing="5">
            <TextBlock Text="{Binding [CurrentPassword], Source={x:Static svc:LocalizationService.Instance}}" FontSize="16" FontWeight="SemiBold"/>
            <TextBox Text="{Binding CurrentPassword}" PasswordChar="*" Height="45"/>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="{Binding [NewPassword], Source={x:Static svc:LocalizationService.Instance}}" FontSize="16" FontWeight="SemiBold"/>
            <TextBox Text="{Binding NewPassword}" PasswordChar="*" Height="45"/>
        </StackPanel>

        <StackPanel Spacing="5">
            <TextBlock Text="{Binding [ConfirmNewPassword], Source={x:Static svc:LocalizationService.Instance}}" FontSize="16" FontWeight="SemiBold"/>
            <TextBox Text="{Binding ConfirmPassword}" PasswordChar="*" Height="45"/>
        </StackPanel>

        <TextBlock Text="{Binding StatusMessage}" 
                   Foreground="{DynamicResource MainTextBrush}" 
                   HorizontalAlignment="Center" 
                   FontSize="14"
                   TextWrapping="Wrap"/>

        <StackPanel Spacing="10" Margin="0,20,0,0">
            <Button Content="{Binding [ApplyChange], Source={x:Static svc:LocalizationService.Instance}}" 
                    Command="{Binding ApplyPasswordChangeCommand}" 
                    Classes="nav"
                    Width="200"
                    Height="48"
                    HorizontalAlignment="Center"/>

            <Button Content="{Binding [Back], Source={x:Static svc:LocalizationService.Instance}}" 
                    Click="Back_Click" 
                    Classes="nav"
                    Width="200"
                    Height="48"
                    HorizontalAlignment="Center" 
                    Margin="0,10,0,0"/>
        </StackPanel>
    </StackPanel>
</UserControl>